import streamlit as st
import pandas as pd
import requests
from geopy.geocoders import Nominatim
from owslib.wfs import WebFeatureService

st.set_page_config(page_title="Protokoll-Analyse NRW", layout="wide")
st.title("🔍 Ziel-Analyse: Operativer Datenzugriff NRW")

# 1. TEST-SETUP: Die Ziel-Adresse
test_adresse = "De-Greiff-Straße 195, Krefeld" # Sitz des Geologischen Dienstes
geolocator = Nominatim(user_agent="nrw_data_inspector")
location = geolocator.geocode(test_adresse + ", NRW")
lat, lon = location.latitude, location.longitude

st.write(f"**Test-Punkt:** {test_adresse} ({lat}, {lon})")

# 2. DEFINITION DER ZIELE (Endpunkte)
targets = [
    {
        "Name": "Ziel A: Neuer GeoServer (IT.NRW)",
        "URL": "https://www.geoserver.nrw.de/geoserver/gd/wfs",
        "Layer": "gd:bk050_bodeneinheiten"
    },
    {
        "Name": "Ziel B: Klassischer WMS-WFS (Legacy)",
        "URL": "https://www.wms.nrw.de/gd/bk050/wfs",
        "Layer": "bk050:is_m_layer"
    },
    {
        "Name": "Ziel C: GetFeatureInfo (Direkt-Abfrage)",
        "URL": "https://www.wms.nrw.de/gd/bk050",
        "Type": "WMS_INFO"
    }
]

# 3. AUSWERTUNGS-LOGIK
results = []

for target in targets:
    st.subheader(target["Name"])
    with st.expander("Technisches Protokoll anzeigen", expanded=True):
        try:
            if target.get("Type") == "WMS_INFO":
                # Simulation des Klicks im Geoportal (GetFeatureInfo)
                params = {
                    "SERVICE": "WMS", "VERSION": "1.3.0", "REQUEST": "GetFeatureInfo",
                    "LAYERS": "is_m_layer", "QUERY_LAYERS": "is_m_layer",
                    "I": 50, "J": 50, "WIDTH": 100, "HEIGHT": 100,
                    "CRS": "EPSG:4326", "BBOX": f"{lat-0.001},{lon-0.001},{lat+0.001},{lon+0.001}",
                    "INFO_FORMAT": "application/json"
                }
                resp = requests.get(target["URL"], params=params, timeout=10)
                if resp.status_code == 200:
                    st.success("Verbindung erfolgreich (HTTP 200)")
                    st.json(resp.json())
                else:
                    st.error(f"Status Code: {resp.status_code}")
            else:
                # WFS-Standard-Abfrage
                wfs = WebFeatureService(url=target["URL"], version='2.0.0')
                st.write(f"Capabilities geladen. Titel: {wfs.identification.title}")
                
                # Test-Abfrage der Features
                response = wfs.getfeature(typename=target["Layer"], 
                                         bbox=(lat-0.0005, lon-0.0005, lat+0.0005, lon+0.0005),
                                         outputFormat='json')
                st.write("Daten-Paket empfangen.")
                st.json(response.read())

        except Exception as e:
            st.error(f"Ziel gescheitert: {str(e)}")

# 4. DIAGNOSE-HINWEIS
